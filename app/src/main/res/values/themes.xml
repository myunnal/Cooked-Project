<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Cookinti" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/burgundy</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!--Button style -->
        <item name="buttonStyle">@style/ButtonStyle</item>
        <item name="materialButtonStyle">@style/ButtonStyle</item>
        <!-- ImageButton style -->
        <item name="android:imageButtonStyle">@style/ImageButtonStyle</item>
        <item name="imageButtonStyle">@style/ImageButtonStyle</item>
        <!-- Universal AlertDialog style -->
        <item name="alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="materialAlertDialogTheme">@style/AppAlertDialogTheme</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.Cookinti.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Cookinti.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.Cookinti.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <!-- Universal dialog theme -->
    <style name="AppAlertDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="colorAccent">@color/burgundy</item>
        <item name="android:colorAccent">@color/burgundy</item>
        <item name="android:paddingStart">5dp</item>
        <item name="android:paddingEnd">7dp</item>
        <item name="materialAlertDialogTitleTextStyle">@style/DialogTitleText</item>
    </style>
    <style name="DialogTitleText" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/burgundy</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Button style -->
    <style name="ButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/sample_buttognnn</item>
        <item name="backgroundTint">@null</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">@color/off_white</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="elevation">100dp</item>
    </style>

    <!-- ImageButton style -->
    <style name="ImageButtonStyle" parent="Widget.AppCompat.ImageButton">
        <item name="android:background">@drawable/sample_buttognnn</item>
        <item name="android:backgroundTint">@null</item>
        <item name="backgroundTint">@null</item>
        <item name="android:tint">@color/off_white</item>
        <item name="tint">@color/off_white</item>
        <item name="android:padding">8dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>



</resources>